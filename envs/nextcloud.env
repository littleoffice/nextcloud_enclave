NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=admin
OBJECTSTORE_S3_BUCKET=nextcloud
OBJECTSTORE_S3_REGION=eu-central-1
OBJECTSTORE_S3_HOST=nas.domain.tld
OBJECTSTORE_S3_PORT=30293
OBJECTSTORE_S3_KEY=nextcloud
OBJECTSTORE_S3_SECRET=NEXTCLOUD_S3_SECRET
OBJECTSTORE_S3_SSL=true
OBJECTSTORE_S3_USEPATH_STYLE=true
OBJECTSTORE_S3_AUTOCREATE=true
NEXTCLOUD_TRUSTED_DOMAINS=192.168.x.x nextcloud.domain.tld
OVERWRITECLIURL=https://nextcloud.domain.tld
OVERWRITEPROTOCOL=https
OVERWRITEHOST=nextcloud.domain.tld
TRUSTED_PROXIES=caddy
POSTGRES_DB=nextcloud
POSTGRES_USER=nextcloud
POSTGRES_PASSWORD=NEXTCLOUD_POSTGRES_SECRET
POSTGRES_HOST=nextcloud-postgres
REDIS_HOST=nextcloud-redis
REDIS_PORT=6379
REDIS_HOST_PASSWORD=NEXTCLOUD_REDIS_SECRET
OIDC_CLIENT_ID=NEXTCLOUD_OIDC_CLIENT_ID
OIDC_CLIENT_SECRET=NEXTCLOUD_OIDC_CLIENT_SECRET
OIDC_LOGIN_SCOPE=openid profile email nextcloud
OIDC_PROVIDER_URL=https://sso.domain.tld/application/o/nextcloud/
OIDC_LOGOUT_URL=https://sso.domain.tld/application/o/nextcloud/end-session/
