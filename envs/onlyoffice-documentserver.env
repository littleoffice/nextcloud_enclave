NODE_EXTRA_CA_CERTS=/etc/ssl/certs/ca-certificates.crt
DB_TYPE=postgres
DB_HOST=onlyoffice-postgres
DB_PORT=5432
DB_PWD=ONLYOFFICE_POSTGRES_SECRET
DB_NAME=onlyoffice
DB_USER=onlyoffice
AMQP_URI=amqp://onlyoffice:ONLYOFFICE_RABBITMQ_SECRET@onlyoffice-rabbitmq
JWT_ENABLED=true
JWT_SECRET=ONLYOFFICE_JWT_SECRET
JWT_HEADER=Authorization
JWT_IN_BODY=true